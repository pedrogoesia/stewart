# Configuração do sistema Stewart.
#
# 1) Copie este arquivo para um novo arquivo chamado ".env"
#    (no Windows PowerShell:  Copy-Item .env.example .env )
# 2) Preencha os valores abaixo conforme a necessidade.
# 3) Reinicie o servidor (python app.py).
#
# ATENÇÃO: nunca suba o arquivo .env para o GitHub (já está no .gitignore).

# ---------------------------------------------------------------------------
# Login / sessão
# ---------------------------------------------------------------------------
# Chave secreta que assina o cookie de login. EM PRODUÇÃO use um valor longo e
# aleatório (ex.: gere com:  python -c "import secrets; print(secrets.token_hex(32))" ).
SECRET_KEY=

# Primeiro usuário administrador, criado automaticamente na 1ª vez que o
# sistema sobe (se ainda não houver nenhum usuário). Depois você cria os
# demais usuários pela tela "Usuários".
ADMIN_EMAIL=admin@stewart.local
ADMIN_SENHA=

# ---------------------------------------------------------------------------
# Banco de dados
# ---------------------------------------------------------------------------
# Em branco = SQLite local (arquivo data/stewart.db), ótimo para desenvolver.
# Em produção, cole aqui a URL do PostgreSQL fornecida pela hospedagem, ex.:
# DATABASE_URL=postgresql://usuario:senha@host:5432/nome_do_banco
DATABASE_URL=

# ---------------------------------------------------------------------------
# Edição de fotos por IA (OpenAI - gpt-image-1) — opcional
# ---------------------------------------------------------------------------
# Pegue uma chave em: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Opcional: trocar o modelo de imagem usado (padrão abaixo).
# OPENAI_IMAGE_MODEL=gpt-image-1
